                "templates/shaka/api/components/_code_tabs.html.twig": {
                    "contents": [
                        "{% set title = title ?? 'Code example' %}",
                        "{% set snippets = snippets ?? {",
                        "  'bash': 'curl https://api.example.com/v1/users',",
                        "  'php': '$client->request(\"GET\", \"/v1/users\");',",
                        "  'javascript': 'await fetch(\"/v1/users\");'",
                        "} %}",
                        "",
                        "<section class=\"shaka-code-tabs\" data-controller=\"shaka-code-tabs\">",
                        "  <header class=\"shaka-code-tabs__header\">",
                        "    <h3>{{ title }}</h3>",
                        "",
                        "    <button",
                        "      type=\"button\"",
                        "      class=\"shaka-code-tabs__copy\"",
                        "      data-controller=\"shaka-copy-code\"",
                        "      data-action=\"click->shaka-copy-code#copy\"",
                        "      data-shaka-copy-code-target-value=\".shaka-code-tabs__panel.is-active code\"",
                        "    >",
                        "      Copy",
                        "    </button>",
                        "  </header>",
                        "",
                        "  <div class=\"shaka-code-tabs__tablist\" role=\"tablist\">",
                        "    {% for language, snippet in snippets %}",
                        "      <button",
                        "        type=\"button\"",
                        "        class=\"shaka-code-tabs__tab{% if loop.first %} is-active{% endif %}\"",
                        "        data-action=\"click->shaka-code-tabs#select\"",
                        "        data-shaka-code-tabs-target=\"tab\"",
                        "        data-shaka-code-tabs-language-param=\"{{ language }}\"",
                        "        role=\"tab\"",
                        "        aria-selected=\"{{ loop.first ? 'true' : 'false' }}\"",
                        "      >",
                        "        {{ language|upper }}",
                        "      </button>",
                        "    {% endfor %}",
                        "  </div>",
                        "",
                        "  <div class=\"shaka-code-tabs__panels\">",
                        "    {% for language, snippet in snippets %}",
                        "      <div",
                        "        class=\"shaka-code-tabs__panel{% if loop.first %} is-active{% endif %}\"",
                        "        data-shaka-code-tabs-target=\"panel\"",
                        "        data-language=\"{{ language }}\"",
                        "        {% if not loop.first %}hidden{% endif %}",
                        "      >",
                        "        <pre><code>{{ snippet }}</code></pre>",
                        "      </div>",
                        "    {% endfor %}",
                        "  </div>",
                        "</section>",
                        ""
                    ],
                    "executable": false
                },
                "templates/shaka/api/components/_endpoint_card.html.twig": {
                    "contents": [
                        "{% set method = method ?? 'GET' %}",
                        "{% set path = path ?? '/v1/example' %}",
                        "{% set title = title ?? 'Example endpoint' %}",
                        "{% set description = description ?? 'A short description of the endpoint.' %}",
                        "{% set auth = auth ?? 'Bearer token' %}",
                        "{% set responses = responses ?? [",
                        "  { code: 200, label: 'OK' },",
                        "  { code: 401, label: 'Unauthorized' }",
                        "] %}",
                        "",
                        "<article class=\"shaka-api-endpoint-card\">",
                        "  <header class=\"shaka-api-endpoint-card__header\">",
                        "    <div class=\"shaka-api-endpoint-card__meta\">",
                        "      <span class=\"shaka-api-method shaka-api-method--{{ method|lower }}\">{{ method }}</span>",
                        "      <code class=\"shaka-api-endpoint-card__path\">{{ path }}</code>",
                        "    </div>",
                        "    <h3 class=\"shaka-api-endpoint-card__title\">{{ title }}</h3>",
                        "    <p class=\"shaka-api-endpoint-card__description\">{{ description }}</p>",
                        "  </header>",
                        "",
                        "  <div class=\"shaka-api-endpoint-card__details\">",
                        "    <p class=\"shaka-api-endpoint-card__auth\"><strong>Auth:</strong> {{ auth }}</p>",
                        "",
                        "    <ul class=\"shaka-api-endpoint-card__responses\">",
                        "      {% for response in responses %}",
                        "        <li>",
                        "          <span class=\"shaka-api-endpoint-card__status\">{{ response.code }}</span>",
                        "          <span>{{ response.label }}</span>",
                        "        </li>",
                        "      {% endfor %}",
                        "    </ul>",
                        "  </div>",
                        "</article>",
                        ""
                    ],
                    "executable": false
                },
