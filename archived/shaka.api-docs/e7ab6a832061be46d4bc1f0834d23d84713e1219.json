                },
                "templates/shaka/api/pages/errors.html.twig": {
                    "contents": [
                        "{% extends 'shaka/api/layout/base.html.twig' %}",
                        "",
                        "{% block title %}Shaka API Errors{% endblock %}",
                        "",
                        "{% block shell %}",
                        "  {% include 'shaka/api/partials/_topbar.html.twig' %}",
                        "",
                        "  <main class=\"shaka-api-page\">",
                        "    <div class=\"shaka-api-page__grid\">",
                        "      {% include 'shaka/api/partials/_sidebar.html.twig' only %}",
                        "",
                        "      <div class=\"shaka-api-page__content\">",
                        "        <header class=\"shaka-api-section\">",
                        "          <span class=\"shaka-api-badge\">Errors</span>",
                        "          <h1>Error handling</h1>",
                        "          <p>Document error payloads and status codes with reusable components.</p>",
                        "        </header>",
                        "",
                        "        {% include 'shaka/api/components/_endpoint_card.html.twig' with {",
                        "          method: 'POST',",
                        "          path: '/v1/users',",
                        "          title: 'Validation error example',",
                        "          description: 'This endpoint can return validation failures.',",
                        "          responses: [",
                        "            { code: 422, label: 'Validation failed' },",
                        "            { code: 401, label: 'Unauthorized' }",
                        "          ]",
                        "        } only %}",
                        "",
                        "        {% include 'shaka/api/components/_code_tabs.html.twig' with {",
                        "          title: 'Example error response',",
                        "          snippets: {",
                        "            'json': '{ \"error\": { \"code\": \"validation_failed\", \"message\": \"The email field is required.\" } }',",
                        "            'php': '$response[\"error\"][\"code\"];',",
                        "            'javascript': 'error.code // validation_failed'",
                        "          }",
                        "        } only %}",
                        "      </div>",
                        "    </div>",
                        "  </main>",
                        "{% endblock %}",
                        ""
                    ],
                    "executable": false
                },
                "templates/shaka/api/pages/overview.html.twig": {
                    "contents": [
                        "{% extends 'shaka/api/layout/base.html.twig' %}",
                        "",
                        "{% block title %}Shaka API Overview{% endblock %}",
                        "",
                        "{% block shell %}",
                        "  {% include 'shaka/api/partials/_topbar.html.twig' %}",
                        "",
                        "  <main class=\"shaka-api-page shaka-api-page--overview\">",
                        "    <div class=\"shaka-api-page__grid\">",
                        "      {% include 'shaka/api/partials/_sidebar.html.twig' only %}",
                        "",
                        "      <div class=\"shaka-api-page__content\">",
                        "        <header class=\"shaka-api-hero\">",
                        "          <span class=\"shaka-api-badge\">Docs</span>",
                        "          <h1>API documentation, fast.</h1>",
                        "          <p>Create clean product docs inspired by Vercel, Stripe and shadcn-style interfaces.</p>",
                        "        </header>",
                        "",
                        "        <section class=\"shaka-api-section\">",
                        "          <h2>Why this bundle?</h2>",
                        "",
                        "          <div class=\"shaka-api-feature-grid\">",
                        "            {% include 'shaka/api/components/_feature_card.html.twig' with {",
                        "              title: 'Single package',",
                        "              text: 'Twig, CSS and Stimulus live in one repository.'",
                        "            } only %}",
                        "",
                        "            {% include 'shaka/api/components/_feature_card.html.twig' with {",
                        "              title: 'Ready for Symfony',",
                        "              text: 'Install with Composer and preview quickly.'",
                        "            } only %}",
                        "",
                        "            {% include 'shaka/api/components/_feature_card.html.twig' with {",
                        "              title: 'Easy to customize',",
                        "              text: 'Each building block stays explicit and localizable.'",
                        "            } only %}",
                        "          </div>",
                        "        </section>",
                        "",
                        "        <section id=\"authentication\" class=\"shaka-api-section\">",
                        "          <h2>Authentication</h2>",
                        "          <p>Every request requires a bearer token passed in the <code>Authorization</code> header.</p>",
                        "",
                        "          {% include 'shaka/api/components/_code_tabs.html.twig' with {",
