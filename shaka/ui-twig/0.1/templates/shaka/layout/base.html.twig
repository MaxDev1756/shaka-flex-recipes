{#
  layout/base.html.twig
  =====================
  Variables:
    - lang          (string)  : HTML lang attribute. Default: 'fr'
    - charset       (string)  : Meta charset. Default: 'UTF-8'
    - title         (string)  : Page <title>. Required.
    - description   (string)  : Meta description.
    - canonical     (string)  : Canonical URL.
    - og            (object)  : Open Graph data { title, description, image, type, url }
    - body_class    (string)  : Extra classes on <body>.
    - skip_link     (boolean) : Show skip-to-content link. Default: true
    - flash_messages (array)  : Array of flash messages passed to _flash partial.

  Blocks:
    - head_meta     : Extra <meta> tags
    - head_styles   : Stylesheets / style blocks
    - head_scripts  : Scripts loaded in <head>
    - body_start    : Immediately after <body> opening
    - skip_link     : Skip navigation link
    - navbar        : Top navigation bar
    - flash         : Flash message region
    - breadcrumbs   : Breadcrumb trail
    - main          : Main page content (override this in child templates)
    - content       : Inner content block inside <main> (override this)
    - footer        : Page footer
    - body_end      : Scripts before </body>
#}
<!DOCTYPE html>
<html lang="{{ lang|default('fr') }}">
<head>
  <meta charset="{{ charset|default('UTF-8') }}">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{% block title %}{{ title|default('Page') }}{% endblock %}</title>

  {% if description is defined and description %}
    <meta name="description" content="{{ description }}">
  {% endif %}

  {% if canonical is defined and canonical %}
    <link rel="canonical" href="{{ canonical }}">
  {% endif %}

  {# Open Graph #}
  {% if og is defined %}
    <meta property="og:title"       content="{{ og.title|default(title) }}">
    <meta property="og:type"        content="{{ og.type|default('website') }}">
    {% if og.description is defined %}
      <meta property="og:description" content="{{ og.description }}">
    {% endif %}
    {% if og.image is defined %}
      <meta property="og:image" content="{{ og.image }}">
    {% endif %}
    {% if og.url is defined %}
      <meta property="og:url" content="{{ og.url }}">
    {% endif %}
  {% endif %}

  {% block head_meta %}{% endblock %}

  {% block head_styles %}{% endblock %}
</head>

<body{% if body_class is defined and body_class %} class="{{ body_class }}"{% endif %}>

{% block body_start %}{% endblock %}

{# ── Skip link ─────────────────────────────────────────────────── #}
{% block skip_link %}
  {% if skip_link is not defined or skip_link != false %}
    {% include 'partials/_skip_link.html.twig' %}
  {% endif %}
{% endblock %}

{# ── Navbar ────────────────────────────────────────────────────── #}
{% block navbar %}
  {% include 'partials/_navbar.html.twig' %}
{% endblock %}

{# ── Flash messages ────────────────────────────────────────────── #}
{% block flash %}
  {% if flash_messages is defined and flash_messages|length %}
    {% for message in flash_messages %}
      {% include 'partials/_flash.html.twig' with { message: message } %}
    {% endfor %}
  {% endif %}
{% endblock %}

{# ── Breadcrumbs ───────────────────────────────────────────────── #}
{% block breadcrumbs %}{% endblock %}

{# ── Main content ──────────────────────────────────────────────── #}
{% block main %}
  <main id="main-content" tabindex="-1">
    {% block content %}{% endblock %}
  </main>
{% endblock %}

{# ── Footer ────────────────────────────────────────────────────── #}
{% block footer %}
  {% include 'partials/_footer.html.twig' %}
{% endblock %}

{% block head_scripts %}{% endblock %}
{% block body_end %}{% endblock %}

</body>
</html>
