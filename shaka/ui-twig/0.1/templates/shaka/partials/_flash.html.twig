{% set messages = flash_messages ?? [] %}
{% if messages %}
  <div class="shaka-flash-stack" aria-live="polite">
    {% for message in messages %}
      {% include 'shaka/components/_alert.html.twig' with {
        variant: message.variant ?? 'info',
        title: message.title ?? null,
        text: message.text ?? message.message ?? ''
      } only %}
    {% endfor %}
  </div>
{% endif %}
