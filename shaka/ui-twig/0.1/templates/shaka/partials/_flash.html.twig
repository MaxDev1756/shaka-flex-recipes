{#
  partials/_flash.html.twig
  ==========================
  Single flash / notification message banner.

  Variables:
    - message (object) : {
        type    (string)  : 'success' | 'error' | 'warning' | 'info'. Default: 'info'
        text    (string)  : Message body. Required.
        title   (string)  : Optional bold heading.
        dismiss (boolean) : Show dismiss button. Default: true
      }

  Usage:
    {% include 'shaka/partials/_flash.html.twig' with { message: { type: 'success', text: 'Enregistré !' } } %}
#}

{% set type  = message.type|default('info') %}
{% set icons = { success: '✓', error: '✕', warning: '⚠', info: 'ℹ' } %}

<div
  role="alert"
  aria-live="polite"
  aria-atomic="true"
  data-flash-type="{{ type }}">

  {# Icon #}
  <span aria-hidden="true">{{ icons[type]|default('ℹ') }}</span>

  {# Text #}
  <div>
    {% if message.title is defined and message.title %}
      <strong>{{ message.title }}</strong>
    {% endif %}
    <span>{{ message.text }}</span>
  </div>

  {# Dismiss button #}
  {% if message.dismiss is not defined or message.dismiss != false %}
    <button
      type="button"
      aria-label="Fermer ce message"
      data-dismiss="flash">
      <span aria-hidden="true">&times;</span>
    </button>
  {% endif %}

</div>
