{% set items = breadcrumbs ?? [] %}
{% if items %}
  <nav class="shaka-breadcrumbs" aria-label="Fil d’Ariane">
    <ol class="shaka-breadcrumbs__list">
      {% for item in items %}
        <li class="shaka-breadcrumbs__item">
          {% if not loop.last and (item.href ?? null) %}
            <a href="{{ item.href }}">{{ item.label ?? 'Item' }}</a>
          {% else %}
            <span aria-current="page">{{ item.label ?? 'Item' }}</span>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </nav>
{% endif %}
