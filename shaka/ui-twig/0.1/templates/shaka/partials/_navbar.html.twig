{#
  partials/_navbar.html.twig
  ===========================
  Barre de navigation responsive.

  Variables :
    - brand     (object) : { name, url, logo }
    - nav_items (array)  : [{ label, url, active, children: [{ label, url }] }]
    - nav_cta   (object) : { label, url, variant }
    - nav_id    (string) : ID de la <nav>. Défaut : 'main-nav'

  Fichier CSS associé : assets/shaka/partials/navbar.css
  Sélecteur racine   : [data-navbar]

  JS requis : toggle data-open sur [data-navbar-menu] au clic sur [data-navbar-toggle]
#}

<header data-navbar>
  <div data-navbar-inner>

    {# ── Brand ──────────────────────────────────────────────── #}
    <div data-navbar-brand>
      <a href="{{ brand.url|default('/') }}">
        {% if brand.logo is defined and brand.logo %}
          <img src="{{ brand.logo }}" alt="{{ brand.name|default('') }}">
        {% else %}
          {{ brand.name|default('Brand') }}
        {% endif %}
      </a>
    </div>

    {# ── Menu ────────────────────────────────────────────────── #}
    <ul
      id="{{ nav_id|default('main-nav') }}-menu"
      role="list"
      data-navbar-menu
    >
      {% if nav_items is defined %}
        {% for item in nav_items %}
          <li{% if item.children is defined and item.children %} aria-haspopup="true"{% endif %}>

            <a
              href="{{ item.url }}"
              {% if item.active is defined and item.active %}aria-current="page"{% endif %}
            >{{ item.label }}</a>

            {% if item.children is defined and item.children %}
              <ul role="list">
                {% for child in item.children %}
                  <li><a href="{{ child.url }}">{{ child.label }}</a></li>
                {% endfor %}
              </ul>
            {% endif %}

          </li>
        {% endfor %}
      {% endif %}
    </ul>

    {# ── CTA ─────────────────────────────────────────────────── #}
    {% if nav_cta is defined and nav_cta %}
      <div data-navbar-cta>
        {% include 'shaka/components/_button.html.twig' with {
          label:   nav_cta.label,
          url:     nav_cta.url,
          variant: nav_cta.variant|default('primary'),
          size:    'sm'
        } %}
      </div>
    {% endif %}

    {# ── Toggle mobile ───────────────────────────────────────── #}
    <button
      type="button"
      aria-controls="{{ nav_id|default('main-nav') }}-menu"
      aria-expanded="false"
      aria-label="Ouvrir le menu"
      data-navbar-toggle
    >
      <span aria-hidden="true">&#9776;</span>
    </button>

  </div>
</header>
