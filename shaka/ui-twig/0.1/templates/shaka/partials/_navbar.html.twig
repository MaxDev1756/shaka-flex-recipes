{#
  partials/_navbar.html.twig
  ===========================
  Responsive navigation bar.

  Variables:
    - brand (object) : { name, url, logo } — Logo / brand name
    - nav_items (array) : [
        {
          label      (string)  : Link text,
          url        (string)  : href,
          active     (boolean) : Is this item the current page?,
          children   (array)   : Optional sub-menu items [{ label, url }]
        }
      ]
    - nav_cta (object) : Optional call-to-action button { label, url, variant }
    - nav_id  (string) : ID for the <nav> element. Default: 'main-nav'
#}

<header>
  <nav id="{{ nav_id|default('main-nav') }}" aria-label="Navigation principale">

    {# ── Brand ─────────────────────────────────────────────────── #}
    <div>
      <a href="{{ brand.url|default('/') }}">
        {% if brand.logo is defined and brand.logo %}
          <img src="{{ brand.logo }}" alt="{{ brand.name|default('') }}">
        {% else %}
          {{ brand.name|default('Brand') }}
        {% endif %}
      </a>
    </div>

    {# ── Toggle (mobile) ───────────────────────────────────────── #}
    <button
      type="button"
      aria-controls="nav-menu"
      aria-expanded="false"
      aria-label="Ouvrir le menu">
      <span aria-hidden="true">&#9776;</span>
    </button>

    {# ── Nav links ─────────────────────────────────────────────── #}
    <ul id="nav-menu" role="list">
      {% if nav_items is defined %}
        {% for item in nav_items %}
          <li{% if item.children is defined and item.children %} aria-haspopup="true"{% endif %}>

            <a href="{{ item.url }}"
               {% if item.active is defined and item.active %}aria-current="page"{% endif %}>
              {{ item.label }}
            </a>

            {# Sub-menu #}
            {% if item.children is defined and item.children %}
              <ul role="list">
                {% for child in item.children %}
                  <li>
                    <a href="{{ child.url }}">{{ child.label }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}

          </li>
        {% endfor %}
      {% endif %}
    </ul>

    {# ── CTA ───────────────────────────────────────────────────── #}
    {% if nav_cta is defined and nav_cta %}
      <div>
        {% include 'components/_button.html.twig' with {
          label:   nav_cta.label,
          url:     nav_cta.url,
          variant: nav_cta.variant|default('primary')
        } %}
      </div>
    {% endif %}

  </nav>
</header>
