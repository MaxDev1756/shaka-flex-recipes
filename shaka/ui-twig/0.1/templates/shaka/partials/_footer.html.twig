{% set links = footer_links ?? [] %}
<footer class="shaka-footer">
  <div class="shaka-container shaka-footer__inner">
    <div class="shaka-footer__brand">
      <strong>{{ footer_brand ?? 'Shaka' }}</strong>
      <p>{{ footer_text ?? 'A simple Twig UI starter kit.' }}</p>
    </div>
    {% if links %}
      <nav class="shaka-footer__nav" aria-label="Liens de pied de page">
        <ul class="shaka-footer__list">
          {% for item in links %}
            <li><a href="{{ item.href ?? '#' }}">{{ item.label ?? 'Link' }}</a></li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}
  </div>
</footer>
