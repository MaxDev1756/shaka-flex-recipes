{#
  components/_icon.html.twig
  ===========================
  SVG sprite icon or inline Unicode/emoji fallback.

  Expects an SVG sprite sheet with <symbol id="icon-{name}"> entries,
  OR falls back to a data-attribute hook for JS-based icon libraries
  (Heroicons, Lucide, Phosphor, etc.).

  Variables:
    - name        (string)  : Icon identifier (e.g. 'arrow-right', 'user'). Required.
    - size        (string)  : 'xs' | 'sm' | 'md' | 'lg' | 'xl'. Default: 'md'
    - label       (string)  : Accessible label. If omitted icon is decorative (aria-hidden).
    - aria_hidden (boolean) : Force aria-hidden="true". Default: false
    - sprite_url  (string)  : Path to SVG sprite file. Default: '/icons/sprite.svg'
    - color       (string)  : currentColor override (e.g. 'inherit', '#ff0000').

  Usage:
    {# Decorative icon #}
    {% include 'components/_icon.html.twig' with { name: 'arrow-right', aria_hidden: true } %}

    {# Meaningful icon (no adjacent text) #}
    {% include 'components/_icon.html.twig' with { name: 'trash', label: 'Supprimer' } %}
#}

{% set decorative = (aria_hidden is defined and aria_hidden) or (label is not defined or not label) %}
{% set sprite     = sprite_url|default('/icons/sprite.svg') %}

<svg
  data-icon="{{ name }}"
  data-size="{{ size|default('md') }}"

  {% if decorative %}
    aria-hidden="true"
    focusable="false"
  {% else %}
    role="img"
    aria-label="{{ label }}"
  {% endif %}

  {% if color is defined and color %}
    style="color: {{ color }};"
  {% endif %}
>
  {% if label is defined and label %}
    <title>{{ label }}</title>
  {% endif %}
  <use href="{{ sprite }}#icon-{{ name }}"></use>
</svg>
