{#
  components/_button.html.twig
  =============================
  Versatile button / link-button component.

  Variables:
    - label    (string)  : Button text. Required.
    - url      (string)  : If set, renders an <a> tag instead of <button>.
    - type     (string)  : Button type attribute: 'button' | 'submit' | 'reset'. Default: 'button'
    - variant  (string)  : Visual style: 'primary' | 'secondary' | 'ghost' | 'danger' | 'link'. Default: 'primary'
    - size     (string)  : 'sm' | 'md' | 'lg'. Default: 'md'
    - disabled (boolean) : Disabled state.
    - loading  (boolean) : Show loading spinner and disable interactions.
    - icon_before (string) : Icon name rendered before label (uses _icon component).
    - icon_after  (string) : Icon name rendered after label.
    - attrs    (object)  : Extra HTML attributes as key/value pairs.
    - external (boolean) : If url set, adds target="_blank" rel="noopener noreferrer".

  Usage:
    {% include 'components/_button.html.twig' with { label: 'Envoyer', variant: 'primary' } %}
    {% include 'components/_button.html.twig' with { label: 'Voir', url: '/page', variant: 'secondary' } %}
#}

{% set is_link    = url is defined and url %}
{% set is_disabled = (disabled is defined and disabled) or (loading is defined and loading) %}
{% set tag        = is_link ? 'a' : 'button' %}

<{{ tag }}
  {% if is_link %}
    href="{{ url }}"
    {% if external is defined and external %}target="_blank" rel="noopener noreferrer"{% endif %}
    {% if is_disabled %}aria-disabled="true" tabindex="-1"{% endif %}
  {% else %}
    type="{{ type|default('button') }}"
    {% if is_disabled %}disabled aria-disabled="true"{% endif %}
  {% endif %}

  data-variant="{{ variant|default('primary') }}"
  data-size="{{ size|default('md') }}"

  {% if loading is defined and loading %}aria-busy="true"{% endif %}

  {% if attrs is defined %}
    {% for attr_key, attr_val in attrs %}
      {{ attr_key }}="{{ attr_val }}"
    {% endfor %}
  {% endif %}
>

  {# Loading spinner #}
  {% if loading is defined and loading %}
    <span aria-hidden="true" data-spinner>&#9696;</span>
  {% endif %}

  {# Icon before label #}
  {% if icon_before is defined and icon_before %}
    {% include 'components/_icon.html.twig' with { name: icon_before, aria_hidden: true } %}
  {% endif %}

  <span>{{ label }}</span>

  {# Icon after label #}
  {% if icon_after is defined and icon_after %}
    {% include 'components/_icon.html.twig' with { name: icon_after, aria_hidden: true } %}
  {% endif %}

</{{ tag }}>
