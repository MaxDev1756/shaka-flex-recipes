{% set label = label ?? 'Button' %}
{% set href = href ?? url ?? null %}
{% set variant = variant ?? 'primary' %}
{% set size = size ?? 'md' %}
{% set type = type ?? 'button' %}
{% set icon_left = icon_left ?? null %}
{% set icon_right = icon_right ?? null %}
{% set class_name = class_name ?? '' %}
{% set attributes = attributes ?? '' %}

{% if href %}
	<a class="shaka-button shaka-button--{{ variant }} shaka-button--{{ size }} {{ class_name|trim }}" href="{{ href }}" {{ attributes|raw }}>
		{% if icon_left %}
			<span class="shaka-button__icon">{{ icon_left }}</span>
		{% endif %}
		<span>{{ label }}</span>
		{% if icon_right %}
			<span class="shaka-button__icon">{{ icon_right }}</span>
		{% endif %}
	</a>
{% else %}
	<button class="shaka-button shaka-button--{{ variant }} shaka-button--{{ size }} {{ class_name|trim }}" type="{{ type }}" {{ attributes|raw }}>
		{% if icon_left %}
			<span class="shaka-button__icon">{{ icon_left }}</span>
		{% endif %}
		<span>{{ label }}</span>
		{% if icon_right %}
			<span class="shaka-button__icon">{{ icon_right }}</span>
		{% endif %}
	</button>
{% endif %}
