{% set title = title ?? 'Card title' %}
{% set text = text ?? description ?? 'A short piece of content to show the visual style of the card component.' %}
{% set eyebrow = eyebrow ?? null %}
{% set href = href ?? null %}
{% set badge = badge ?? null %}
{% set actions = actions ?? [] %}
<article class="shaka-card">
  {% if eyebrow or badge %}
    <div class="shaka-card__meta">
      {% if eyebrow %}<span class="shaka-card__eyebrow">{{ eyebrow }}</span>{% endif %}
      {% if badge %}{% include 'shaka/components/_badge.html.twig' with badge only %}{% endif %}
    </div>
  {% endif %}
  <div class="shaka-card__body">
    <h3 class="shaka-card__title">{{ title }}</h3>
    <p class="shaka-card__text">{{ text }}</p>
  </div>
  {% if href or actions %}
    <div class="shaka-card__footer">
      {% if href %}{% include 'shaka/components/_link.html.twig' with { label: link_label ?? 'Learn more', href: href } only %}{% endif %}
      {% for action in actions %}{% include 'shaka/components/_button.html.twig' with action only %}{% endfor %}
    </div>
  {% endif %}
</article>
