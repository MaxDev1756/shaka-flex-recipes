{% set variant = variant ?? 'info' %}
{% set title = title ?? null %}
{% set text = text ?? 'This is a helpful message.' %}
<div class="shaka-alert shaka-alert--{{ variant }}" role="status">
  {% if title %}<strong class="shaka-alert__title">{{ title }}</strong>{% endif %}
  <div class="shaka-alert__text">{{ text }}</div>
</div>
