{#
  components/_link.html.twig
  ===========================
  Semantic hyperlink component with optional icon and external handling.

  Variables:
    - label    (string)  : Link text. Required unless block content is used.
    - url      (string)  : href value. Required.
    - external (boolean) : Opens in new tab with rel="noopener noreferrer". Default: false
    - title    (string)  : HTML title attribute.
    - download (boolean) : Add download attribute.
    - aria_label (string): Override accessible label.
    - icon_before (string) : Icon name before text.
    - icon_after  (string) : Icon name after text.
    - variant  (string)  : 'default' | 'muted' | 'underline' | 'no-underline'. Default: 'default'

  Usage:
    {% include 'components/_link.html.twig' with { label: 'En savoir plus', url: '/about' } %}
#}

<a
  href="{{ url }}"

  {% if external is defined and external %}
    target="_blank"
    rel="noopener noreferrer"
  {% endif %}

  {% if title is defined and title %}
    title="{{ title }}"
  {% endif %}

  {% if download is defined and download %}
    download
  {% endif %}

  {% if aria_label is defined and aria_label %}
    aria-label="{{ aria_label }}"
  {% endif %}

  data-variant="{{ variant|default('default') }}"
>

  {% if icon_before is defined and icon_before %}
    {% include 'components/_icon.html.twig' with { name: icon_before, aria_hidden: true } %}
  {% endif %}

  {{ label }}

  {% if icon_after is defined and icon_after %}
    {% include 'components/_icon.html.twig' with { name: icon_after, aria_hidden: true } %}
  {% endif %}

  {# Visual cue for external links (screen-reader friendly) #}
  {% if external is defined and external %}
    <span aria-label="(ouvre dans un nouvel onglet)">&#8599;</span>
  {% endif %}

</a>
