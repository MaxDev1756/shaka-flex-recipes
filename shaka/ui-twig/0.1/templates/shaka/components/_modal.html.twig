{% set title = title ?? 'Modal title' %}
{% set text = text ?? 'This is a modal preview.' %}

<div class="shaka-modal" data-controller="shaka-modal" data-state="closed">
	{% include 'shaka/components/_button.html.twig' with {
    label: 'Open modal',
    variant: 'secondary',
    size: 'sm',
    class_name: 'shaka-modal__trigger',
    attributes: 'data-action="click->shaka-modal#open"'
  } only %}

	<div class="shaka-modal__overlay" data-shaka-modal-target="overlay" data-action="click->shaka-modal#closeOnOverlay" hidden>
		<div class="shaka-modal__dialog" data-shaka-modal-target="dialog" hidden>
			<div class="shaka-modal__header">
				<h3>{{ title }}</h3>
			</div>

			<div class="shaka-modal__body">
				<p>{{ text }}</p>
			</div>

			<div class="shaka-modal__footer">
				{% include 'shaka/components/_button.html.twig' with {
          label: 'Close',
          variant: 'secondary',
          size: 'sm',
          attributes: 'data-action="click->shaka-modal#close"'
        } only %}

				{% include 'shaka/components/_button.html.twig' with {
          label: 'Confirm',
          size: 'sm'
        } only %}
			</div>
		</div>
	</div>
</div>
