{#
  components/_dropdown.html.twig
  ===============================
  Accessible dropdown menu (requires JS to toggle aria-expanded / visibility).

  Variables:
    - id       (string)  : Unique ID for the menu (required for aria pairing).
    - trigger  (object)  : Button props: { label, icon, variant, size }
    - items    (array)   : [
        {
          type    (string) : 'item' | 'divider' | 'header'. Default: 'item'
          label   (string) : Display text.
          url     (string) : If set, renders <a> instead of <button>.
          icon    (string) : Optional icon name.
          disabled (bool)  : Disable this item.
          danger  (bool)   : Style as destructive action.
        }
      ]
    - align    (string)  : Menu alignment: 'start' | 'end'. Default: 'start'
    - position (string)  : 'bottom' | 'top'. Default: 'bottom'

  Requires JS:
    - Toggle aria-expanded on trigger click
    - Close on outside click / Escape key
    - Keyboard navigation (Arrow Up/Down, Home, End)

  Usage:
    {% include 'shaka/components/_dropdown.html.twig' with {
      id: 'user-menu',
      trigger: { label: 'Mon compte', icon: 'user' },
      items: [
        { label: 'Profil', url: '/profile', icon: 'user' },
        { label: 'Paramètres', url: '/settings', icon: 'settings' },
        { type: 'divider' },
        { label: 'Déconnexion', url: '/logout', danger: true }
      ]
    } %}
#}

<div data-dropdown data-align="{{ align|default('start') }}" data-position="{{ position|default('bottom') }}">

  {# ── Trigger button ────────────────────────────────────────── #}
  <button
    type="button"
    id="{{ id }}-trigger"
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="{{ id }}-menu"
    data-dropdown-trigger
    data-variant="{{ trigger.variant|default('secondary') }}"
    data-size="{{ trigger.size|default('md') }}"
  >
    {% if trigger.icon is defined %}
      {% include 'shaka/components/_icon.html.twig' with { name: trigger.icon, aria_hidden: true } %}
    {% endif %}
    <span>{{ trigger.label|default('Options') }}</span>
    <span aria-hidden="true" data-dropdown-chevron>&#9660;</span>
  </button>

  {# ── Menu ──────────────────────────────────────────────────── #}
  <ul
    id="{{ id }}-menu"
    role="menu"
    aria-labelledby="{{ id }}-trigger"
    data-dropdown-menu
    hidden
  >
    {% for item in items %}

      {# Divider #}
      {% if item.type is defined and item.type == 'divider' %}
        <li role="separator" data-dropdown-divider></li>

      {# Group header #}
      {% elseif item.type is defined and item.type == 'header' %}
        <li role="presentation" data-dropdown-header>
          <span>{{ item.label }}</span>
        </li>

      {# Regular item #}
      {% else %}
        <li role="presentation">
          {% if item.url is defined and item.url %}
            <a
              href="{{ item.url }}"
              role="menuitem"
              {% if item.disabled is defined and item.disabled %}
                aria-disabled="true" tabindex="-1"
              {% endif %}
              {% if item.danger is defined and item.danger %}data-danger{% endif %}
            >
              {% if item.icon is defined %}
                {% include 'shaka/components/_icon.html.twig' with { name: item.icon, aria_hidden: true } %}
              {% endif %}
              {{ item.label }}
            </a>
          {% else %}
            <button
              type="button"
              role="menuitem"
              {% if item.disabled is defined and item.disabled %}
                disabled aria-disabled="true"
              {% endif %}
              {% if item.danger is defined and item.danger %}data-danger{% endif %}
            >
              {% if item.icon is defined %}
                {% include 'shaka/components/_icon.html.twig' with { name: item.icon, aria_hidden: true } %}
              {% endif %}
              {{ item.label }}
            </button>
          {% endif %}
        </li>
      {% endif %}

    {% endfor %}
  </ul>

</div>
