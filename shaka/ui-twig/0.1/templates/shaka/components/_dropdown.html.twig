{% set label = label ?? 'Dropdown' %}
{% set items = items ?? [
  { label: 'Profile', href: '#' },
  { label: 'Settings', href: '#' },
  { label: 'Sign out', href: '#' }
] %}

<div class="shaka-dropdown" data-controller="shaka-dropdown" data-state="closed">
	{% include 'shaka/components/_button.html.twig' with {
    label: label,
    variant: 'secondary',
    size: 'sm',
    class_name: 'shaka-dropdown__trigger',
    attributes: 'aria-expanded="false" data-shaka-dropdown-target="button" data-action="click->shaka-dropdown#toggle"'
  } only %}

	<div class="shaka-dropdown__menu" data-shaka-dropdown-target="menu" hidden>
		{% for item in items %}
			<a class="shaka-dropdown__item" href="{{ item.href ?? '#' }}">
				{{ item.label ?? 'Item' }}
			</a>
		{% endfor %}
	</div>
</div>
