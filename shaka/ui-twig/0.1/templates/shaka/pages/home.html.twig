{#
  pages/home.html.twig
  =====================
  Homepage. Composes all major marketing sections.

  Variables (passed through to each section):
    See individual section templates for their variables.
    All section data can be passed as top-level variables with the
    convention: hero_*, features_*, stats_*, etc.

  Usage (Symfony / Twig controller):
    return $this->render('pages/home.html.twig', [
      'title'       => 'Accueil – MonProduit',
      'description' => 'Description de la page pour le SEO',
      'hero' => [
        'headline'    => 'Transformez votre façon de travailler',
        'subheadline' => 'La plateforme tout-en-un pour les équipes modernes.',
        'cta_primary' => ['label' => 'Essai gratuit', 'url' => '/signup'],
      ],
      ...
    ]);
#}

{% extends 'layout/base.html.twig' %}

{% block title %}{{ title|default('Accueil') }}{% endblock %}

{% block content %}

  {# ── Hero ─────────────────────────────────────────────────── #}
  {% if hero is defined %}
    {% include 'sections/_hero.html.twig' with hero %}
  {% endif %}

  {# ── Logo strip ────────────────────────────────────────────── #}
  {% if logos is defined %}
    {% include 'sections/_logos.html.twig' with logos %}
  {% endif %}

  {# ── Features ─────────────────────────────────────────────── #}
  {% if features is defined %}
    {% include 'sections/_features.html.twig' with features %}
  {% endif %}

  {# ── Stats ─────────────────────────────────────────────────── #}
  {% if stats is defined %}
    {% include 'sections/_stats.html.twig' with stats %}
  {% endif %}

  {# ── Testimonials ─────────────────────────────────────────── #}
  {% if testimonials is defined %}
    {% include 'sections/_testimonials.html.twig' with testimonials %}
  {% endif %}

  {# ── Pricing ──────────────────────────────────────────────── #}
  {% if pricing is defined %}
    {% include 'sections/_pricing.html.twig' with pricing %}
  {% endif %}

  {# ── FAQ ──────────────────────────────────────────────────── #}
  {% if faq is defined %}
    {% include 'sections/_faq.html.twig' with faq %}
  {% endif %}

  {# ── CTA ──────────────────────────────────────────────────── #}
  {% if cta is defined %}
    {% include 'sections/_cta.html.twig' with cta %}
  {% endif %}

{% endblock %}
