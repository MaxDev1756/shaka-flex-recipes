{% extends 'shaka/layout/base.html.twig' %}
{% block title %}Shaka — Showcase
{% endblock %}

{% block content %}
	<section class="shaka-page shaka-page--showcase">
		<div class="shaka-container shaka-page__inner shaka-stack-lg">
			<header class="shaka-page__header">
				<h1>Shaka showcase</h1>
				<p>A simple preview page to discover the default rendering of each component, section and layout part.</p>
			</header>

			<section class="shaka-showcase-block">
				<h2>Buttons</h2>
				<div class="shaka-inline">
					{% include 'shaka/components/_button.html.twig' with { label: 'Primary' } only %}
					{% include 'shaka/components/_button.html.twig' with { label: 'Secondary', variant: 'secondary' } only %}
					{% include 'shaka/components/_button.html.twig' with { label: 'Ghost', variant: 'ghost' } only %}
				</div>
			</section>

			<section class="shaka-showcase-block">
				<h2>Feedback</h2>
				<div class="shaka-stack">
					{% include 'shaka/components/_alert.html.twig' with { title: 'Info', text: 'A default informational alert.' } only %}
					{% include 'shaka/components/_alert.html.twig' with { variant: 'success', title: 'Success', text: 'A success alert with a clearer state.' } only %}
				</div>
			</section>

			<section class="shaka-showcase-block">
				<h2>Cards</h2>
				<div class="shaka-grid shaka-grid--3">
					{% include 'shaka/components/_card.html.twig' with { title: 'Starter', text: 'Simple defaults make it easier to understand.' } only %}
					{% include 'shaka/components/_card.html.twig' with { title: 'Customizable', text: 'Each component has its own CSS file.', badge: { label: 'CSS', variant: 'brand' } } only %}
					{% include 'shaka/components/_card.html.twig' with { title: 'Ready for JS', text: 'Interactive pieces can be enhanced with Stimulus.' } only %}
				</div>
			</section>

			<section class="shaka-showcase-block">
				<h2>Other components</h2>
				<div class="shaka-inline">
					{% include 'shaka/components/_badge.html.twig' with { label: 'Neutral' } only %}
					{% include 'shaka/components/_badge.html.twig' with { label: 'Brand', variant: 'brand' } only %}
					{% include 'shaka/components/_link.html.twig' with { label: 'Text link', href: '#' } only %}
					{% include 'shaka/components/_avatar.html.twig' with { name: 'Maxime' } only %}
				</div>
			</section>

			<section class="shaka-showcase-block shaka-showcase-block--interactive">
				<h2>Interactive components</h2>
				<div class="shaka-grid shaka-grid--2">
					{% include 'shaka/components/_dropdown.html.twig' only %}
					{% include 'shaka/components/_modal.html.twig' only %}
				</div>
			</section>

			<section class="shaka-showcase-block">
				<h2>Partials</h2>

				<div class="shaka-showcase-preview shaka-showcase-preview--spaced">
					<div class="shaka-showcase-surface">
						{% include 'shaka/partials/_skip_link.html.twig' with {
								show_always: true
							} only %}
					</div>

					<div class="shaka-showcase-surface">
						{% include 'shaka/partials/_breadcrumbs.html.twig' with {
						breadcrumbs: [
							{ label: 'Home', href: '/' },
							{ label: 'Library', href: '#' },
							{ label: 'Showcase' }
						]
						} only %}
					</div>

					<div class="shaka-showcase-surface">
						{% include 'shaka/partials/_flash.html.twig' with {
							flash_messages: [
							{
								variant: 'success',
								title: 'Success',
								text: 'Your action was successful.'
							},
							{
								variant: 'warning',
								title: 'Warning',
								text: 'This is a warning message.'
							}
							]
						} only %}
					</div>

					<div class="shaka-showcase-navbar-preview">
						{% include 'shaka/partials/_navbar.html.twig' only %}
					</div>

					<div class="shaka-showcase-footer-preview">
						{% include 'shaka/partials/_footer.html.twig' only %}
					</div>
				</div>
			</section>

			<section class="shaka-showcase-block">
				<h2>Sections</h2>
				<div class="shaka-showcase-section-stack">
					{% include 'shaka/sections/_hero.html.twig' only %}
					{% include 'shaka/sections/_features.html.twig' only %}
					{% include 'shaka/sections/_stats.html.twig' only %}
					{% include 'shaka/sections/_logos.html.twig' only %}
					{% include 'shaka/sections/_testimonials.html.twig' only %}
					{% include 'shaka/sections/_pricing.html.twig' only %}
					{% include 'shaka/sections/_faq.html.twig' only %}
					{% include 'shaka/sections/_cta.html.twig' only %}
				</div>
			</section>
		</div>
	</section>
{% endblock %}
