{% extends 'shaka/layout/base.html.twig' %}
{% block title %}Shaka — Showcase{% endblock %}
{% block content %}
  <section class="shaka-page shaka-page--showcase">
    <div class="shaka-container shaka-page__inner shaka-stack-lg">
      <header class="shaka-page__header">
        <h1>Shaka showcase</h1>
        <p>A simple preview page to discover the default rendering of each component.</p>
      </header>
      <section class="shaka-showcase-block">
        <h2>Buttons</h2>
        <div class="shaka-inline">
          {% include 'shaka/components/_button.html.twig' with { label: 'Primary' } only %}
          {% include 'shaka/components/_button.html.twig' with { label: 'Secondary', variant: 'secondary' } only %}
          {% include 'shaka/components/_button.html.twig' with { label: 'Ghost', variant: 'ghost' } only %}
        </div>
      </section>
      <section class="shaka-showcase-block">
        <h2>Feedback</h2>
        <div class="shaka-stack">
          {% include 'shaka/components/_alert.html.twig' with { title: 'Info', text: 'A default informational alert.' } only %}
          {% include 'shaka/components/_alert.html.twig' with { variant: 'success', title: 'Success', text: 'A success alert with a clearer state.' } only %}
        </div>
      </section>
      <section class="shaka-showcase-block">
        <h2>Cards</h2>
        <div class="shaka-grid shaka-grid--3">
          {% include 'shaka/components/_card.html.twig' with { title: 'Starter', text: 'Simple defaults make it easier to understand.' } only %}
          {% include 'shaka/components/_card.html.twig' with { title: 'Customizable', text: 'Each component has its own CSS file.', badge: { label: 'CSS', variant: 'brand' } } only %}
          {% include 'shaka/components/_card.html.twig' with { title: 'Ready for JS', text: 'Interactive pieces can later be enhanced with Stimulus.' } only %}
        </div>
      </section>
      <section class="shaka-showcase-block">
        <h2>Other components</h2>
        <div class="shaka-inline">
          {% include 'shaka/components/_badge.html.twig' with { label: 'Neutral' } only %}
          {% include 'shaka/components/_badge.html.twig' with { label: 'Brand', variant: 'brand' } only %}
          {% include 'shaka/components/_link.html.twig' with { label: 'Text link', href: '#' } only %}
          {% include 'shaka/components/_avatar.html.twig' with { name: 'Maxime' } only %}
        </div>
        <div class="shaka-grid shaka-grid--2">
          {% include 'shaka/components/_dropdown.html.twig' %}
          {% include 'shaka/components/_modal.html.twig' %}
        </div>
      </section>
    </div>
  </section>
{% endblock %}
