{% extends 'shaka/layout/base.html.twig' %}
{% block title %}{{ title ?? 'Shaka — Content page' }}{% endblock %}
{% block breadcrumbs %}
  {% include 'shaka/partials/_breadcrumbs.html.twig' with {
    breadcrumbs: [
      { label: 'Home', href: '/' },
      { label: 'Content' }
    ]
  } only %}
{% endblock %}
{% block content %}
  <section class="shaka-page shaka-page--content">
    <div class="shaka-container shaka-page__inner">
      <header class="shaka-page__header">
        {% include 'shaka/components/_badge.html.twig' with { label: 'Article', variant: 'brand' } only %}
        <h1>{{ heading ?? 'A clean content page' }}</h1>
        <p>{{ intro ?? 'Use this page as a readable base for documentation, blog posts or marketing content.' }}</p>
      </header>
      <div class="shaka-prose">
        <p>Shaka is built to be understandable for beginners. Templates keep their default values, CSS stays close to each component and the markup remains easy to read.</p>
        <h2>What makes it simpler</h2>
        <ul>
          <li>One component, one Twig file, one CSS file.</li>
          <li>Few variables, with useful defaults.</li>
          <li>No heavy logic in the templates.</li>
        </ul>
      </div>
      <div class="shaka-stack">
        {% include 'shaka/components/_alert.html.twig' with { variant: 'info', title: 'Tip', text: 'This page is here to show the default typography and content rhythm.' } only %}
        {% include 'shaka/components/_card.html.twig' with { title: 'Reusable content block', text: 'Cards are intentionally simple and can be reused in articles, dashboards or landing pages.', href: '#' } only %}
      </div>
    </div>
  </section>
{% endblock %}
