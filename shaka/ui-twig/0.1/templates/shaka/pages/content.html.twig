{#
  pages/content.html.twig
  ========================
  Generic rich-content page: articles, blog posts, legal pages, documentation, etc.

  Variables:
    - title        (string)  : Page title. Required.
    - description  (string)  : Meta description.
    - eyebrow      (string)  : Category label above title.
    - headline     (string)  : Display heading (can differ from <title>).
    - lead         (string)  : Introductory paragraph / lede.
    - published_at (string)  : ISO 8601 publication date, e.g. '2024-06-01'.
    - updated_at   (string)  : ISO 8601 last-updated date.
    - author       (object)  : { name, role, avatar: { src, alt } }
    - reading_time (string)  : E.g. '5 min de lecture'.
    - cover        (object)  : { src, alt, caption } — hero image.
    - tags         (array)   : Array of tag strings or { label, url } objects.
    - toc          (array)   : Table of contents: [{ label, anchor }]
    - breadcrumbs  (array)   : Breadcrumb items (see _breadcrumbs partial).
    - related      (array)   : Related articles — array of card props.
    - share        (boolean) : Show social sharing links. Default: false

  Block:
    - article_body : The main HTML/Markdown rendered content. Override this block.

  Usage:
    {% extends 'shaka/pages/content.html.twig' %}
    {% block article_body %}
      <p>Mon contenu rendu ici…</p>
    {% endblock %}
#}

{% extends 'shaka/layout/base.html.twig' %}

{% block title %}{{ title|default('Article') }}{% endblock %}

{% block breadcrumbs %}
  {% if breadcrumbs is defined and breadcrumbs %}
    {% include 'shaka/partials/_breadcrumbs.html.twig' with { breadcrumbs: breadcrumbs } %}
  {% endif %}
{% endblock %}

{% block content %}

  <article data-page="content">

    {# ── Article header ──────────────────────────────────────── #}
    <header data-article-header>

      {% if eyebrow is defined and eyebrow %}
        <p data-article-eyebrow>{{ eyebrow }}</p>
      {% endif %}

      <h1 data-article-headline>{{ headline|default(title) }}</h1>

      {% if lead is defined and lead %}
        <p data-article-lead>{{ lead }}</p>
      {% endif %}

      {# Meta row #}
      <div data-article-meta>
        {% if author is defined and author %}
          <div data-author>
            {% if author.avatar is defined %}
              {% include 'shaka/components/_avatar.html.twig' with {
                src:  author.avatar.src,
                alt:  author.avatar.alt|default(author.name),
                name: author.name,
                size: 'sm'
              } %}
            {% endif %}
            <div>
              <span data-author-name>{{ author.name }}</span>
              {% if author.role is defined %}
                <span data-author-role>{{ author.role }}</span>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% if published_at is defined and published_at %}
          <time datetime="{{ published_at }}" data-article-date>
            {{ published_at|date('d MMMM Y') }}
          </time>
        {% endif %}

        {% if updated_at is defined and updated_at %}
          <time datetime="{{ updated_at }}" data-article-updated>
            Mis à jour le {{ updated_at|date('d MMMM Y') }}
          </time>
        {% endif %}

        {% if reading_time is defined and reading_time %}
          <span data-reading-time>{{ reading_time }}</span>
        {% endif %}
      </div>

      {# Tags #}
      {% if tags is defined and tags|length %}
        <ul role="list" data-article-tags>
          {% for tag in tags %}
            <li>
              {% if tag is iterable %}
                {% include 'shaka/components/_badge.html.twig' with { label: tag.label, variant: 'outline' } %}
              {% else %}
                {% include 'shaka/components/_badge.html.twig' with { label: tag, variant: 'outline' } %}
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}

    </header>

    {# ── Cover image ─────────────────────────────────────────── #}
    {% if cover is defined and cover %}
      <figure data-article-cover>
        <img
          src="{{ cover.src }}"
          alt="{{ cover.alt|default('') }}"
          loading="eager"
          fetchpriority="high">
        {% if cover.caption is defined and cover.caption %}
          <figcaption>{{ cover.caption }}</figcaption>
        {% endif %}
      </figure>
    {% endif %}

    {# ── Layout: sidebar ToC + body ───────────────────────────── #}
    <div data-article-layout>

      {# Table of contents sidebar #}
      {% if toc is defined and toc|length %}
        <aside data-article-toc aria-label="Sommaire">
          <nav>
            <p data-toc-heading>Sommaire</p>
            <ol role="list">
              {% for entry in toc %}
                <li>
                  <a href="#{{ entry.anchor }}">{{ entry.label }}</a>
                </li>
              {% endfor %}
            </ol>
          </nav>
        </aside>
      {% endif %}

      {# ── Body ──────────────────────────────────────────────── #}
      <div data-article-body>
        {% block article_body %}{% endblock %}
      </div>

    </div>

    {# ── Share ───────────────────────────────────────────────── #}
    {% if share is defined and share %}
      <div data-article-share>
        <p>Partager cet article :</p>
        {# Replace hrefs with real share URLs in your controller / macro #}
        {% include 'shaka/components/_link.html.twig' with { label: 'Twitter', url: '#', external: true } %}
        {% include 'shaka/components/_link.html.twig' with { label: 'LinkedIn', url: '#', external: true } %}
      </div>
    {% endif %}

  </article>

  {# ── Related articles ────────────────────────────────────── #}
  {% if related is defined and related|length %}
    <aside data-related-articles aria-label="Articles connexes">
      <h2>Articles connexes</h2>
      <ul role="list" data-related-grid>
        {% for article in related %}
          <li>
            {% include 'shaka/components/_card.html.twig' with article %}
          </li>
        {% endfor %}
      </ul>
    </aside>
  {% endif %}

{% endblock %}
