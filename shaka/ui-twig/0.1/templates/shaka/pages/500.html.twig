{#
  pages/500.html.twig
  ====================
  HTTP 500 – Erreur interne du serveur.

  ⚠ Keep this template as standalone as possible — avoid includes that
    could themselves trigger errors (e.g. DB-dependent nav items).
    Consider inlining critical markup here instead of using partials.

  Variables:
    - title      (string) : Page title. Default: '500 – Erreur serveur'
    - headline   (string) : H1 displayed to user.
    - message    (string) : Friendly explanation.
    - error_id   (string) : Optional incident / correlation ID to show.
    - status_url (string) : Link to status page (e.g. status.example.com).
    - cta        (object) : { label, url } back home button.

  Usage (Symfony):
    templates/bundles/TwigBundle/Exception/error500.html.twig
    {% extends 'shaka/pages/500.html.twig' %}
#}

{% extends 'shaka/layout/base.html.twig' %}

{% block title %}{{ title|default('500 – Erreur serveur') }}{% endblock %}

{% block content %}

  <main data-page="error-500" id="main-content" tabindex="-1">

    <div data-error-inner>

      {# Status code #}
      <p data-error-code aria-hidden="true">500</p>

      <h1 data-error-headline>
        {{ headline|default('Une erreur est survenue') }}
      </h1>

      <p data-error-message>
        {{ message|default('Nos équipes ont été averties et travaillent à résoudre le problème. Merci de réessayer dans quelques instants.') }}
      </p>

      {# Incident / correlation ID #}
      {% if error_id is defined and error_id %}
        <p data-error-id>
          Référence de l'incident :
          <code>{{ error_id }}</code>
        </p>
      {% endif %}

      {# Actions #}
      <div data-error-actions>

        {% include 'shaka/components/_button.html.twig' with {
          label:   cta.label|default('Retour à l\'accueil'),
          url:     cta.url|default('/'),
          variant: 'primary',
          size:    'lg'
        } %}

        <button
          type="button"
          onclick="window.location.reload()"
          data-variant="secondary"
          data-size="lg">
          Réessayer
        </button>

      </div>

      {# Status page link #}
      {% if status_url is defined and status_url %}
        <p data-error-status>
          Consultez notre
          {% include 'shaka/components/_link.html.twig' with {
            label:    'page de statut',
            url:      status_url,
            external: true
          } %}
          pour les informations en temps réel.
        </p>
      {% endif %}

    </div>

  </main>

{% endblock %}
