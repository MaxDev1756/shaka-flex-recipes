{#
  pages/404.html.twig
  ====================
  HTTP 404 – Page introuvable.

  Variables:
    - title      (string) : Page title. Default: '404 – Page introuvable'
    - headline   (string) : H1 displayed to user. Default: 'Page introuvable'
    - message    (string) : Explanatory paragraph. Default: generic message.
    - cta        (object) : Button to go back home. Default: { label: 'Retour à l'accueil', url: '/' }
    - search_url (string) : If set, show a search form pointing to this URL.
    - links      (array)  : Helpful links: [{ label, url }]

  Usage (Symfony):
    # config/packages/twig.yaml
    twig:
      exception_controller: null
    # Then map 404 in error pages: templates/bundles/TwigBundle/Exception/error404.html.twig
    {% extends 'pages/404.html.twig' %}
#}

{% extends 'layout/base.html.twig' %}

{% block title %}{{ title|default('404 – Page introuvable') }}{% endblock %}

{% block content %}

  <main data-page="error-404" id="main-content" tabindex="-1">

    <div data-error-inner>

      {# Status code #}
      <p data-error-code aria-hidden="true">404</p>

      <h1 data-error-headline>{{ headline|default('Page introuvable') }}</h1>

      <p data-error-message>
        {{ message|default('La page que vous cherchez n\'existe pas ou a été déplacée.') }}
      </p>

      {# Search #}
      {% if search_url is defined and search_url %}
        <form action="{{ search_url }}" method="get" role="search" data-error-search>
          <label for="error-search-input">Rechercher sur le site</label>
          <input
            id="error-search-input"
            type="search"
            name="q"
            placeholder="Rechercher…"
            autocomplete="off">
          {% include 'components/_button.html.twig' with {
            label: 'Rechercher',
            type: 'submit',
            variant: 'primary'
          } %}
        </form>
      {% endif %}

      {# Main CTA #}
      <div data-error-actions>
        {% include 'components/_button.html.twig' with {
          label:   cta.label|default('Retour à l\'accueil'),
          url:     cta.url|default('/'),
          variant: 'primary',
          size:    'lg'
        } %}
      </div>

      {# Helpful links #}
      {% if links is defined and links|length %}
        <nav data-error-links aria-label="Pages utiles">
          <p>Peut-être cherchez-vous :</p>
          <ul role="list">
            {% for link in links %}
              <li>
                {% include 'components/_link.html.twig' with { label: link.label, url: link.url } %}
              </li>
            {% endfor %}
          </ul>
        </nav>
      {% endif %}

    </div>

  </main>

{% endblock %}
