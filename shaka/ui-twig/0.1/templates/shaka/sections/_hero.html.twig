{% set eyebrow = eyebrow ?? 'Shaka UI' %}
{% set title = title ?? headline ?? 'Build clean Symfony pages faster.' %}
{% set text = text ?? subheadline ?? 'A minimal Twig starter kit with clear templates, sensible defaults and a fast CSS architecture.' %}
{% set primary = primary ?? cta_primary ?? { label: 'Get started', href: '/shaka/showcase' } %}
{% set secondary = secondary ?? cta_secondary ?? { label: 'See components', href: '/shaka/showcase', variant: 'secondary' } %}
<section class="shaka-hero">
  <div class="shaka-container shaka-hero__inner">
    <div class="shaka-hero__content">
      <p class="shaka-hero__eyebrow">{{ eyebrow }}</p>
      <h1 class="shaka-hero__title">{{ title }}</h1>
      <p class="shaka-hero__text">{{ text }}</p>
      <div class="shaka-hero__actions">
        {% include 'shaka/components/_button.html.twig' with primary only %}
        {% include 'shaka/components/_button.html.twig' with secondary only %}
      </div>
    </div>
    <div class="shaka-hero__panel">
      {% include 'shaka/components/_card.html.twig' with {
        eyebrow: 'Preview',
        title: 'Simple by default',
        text: 'Templates are readable, CSS is modular and every component has a visible default state.',
        badge: { label: 'Starter', variant: 'brand' }
      } only %}
    </div>
  </div>
</section>
