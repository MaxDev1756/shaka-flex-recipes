{% set logos = logos ?? ['Acme', 'Orbit', 'North', 'Pixel', 'Mono'] %}
<section class="shaka-logos" aria-label="Trusted by">
  <div class="shaka-container">
    <div class="shaka-logos__list">
      {% for logo in logos %}
        <span class="shaka-logos__item">{{ logo }}</span>
      {% endfor %}
    </div>
  </div>
</section>
