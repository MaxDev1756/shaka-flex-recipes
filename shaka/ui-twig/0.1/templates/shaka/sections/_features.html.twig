{% set title = title ?? 'Core features' %}
{% set text = text ?? 'A small set of useful building blocks for marketing pages and content pages.' %}
{% set items = items ?? [
  { title: 'Simple Twig API', text: 'Use includes with a few clear variables and useful defaults.' },
  { title: 'CSS per component', text: 'Every component has its own stylesheet so it is easy to find and edit.' },
  { title: 'Fast to customize', text: 'Tokens, classes and layouts are designed to be easy to override.' }
] %}
<section class="shaka-features">
  <div class="shaka-container">
    <div class="shaka-section-heading">
      <h2>{{ title }}</h2>
      <p>{{ text }}</p>
    </div>
    <div class="shaka-features__grid">
      {% for item in items %}
        {% include 'shaka/components/_card.html.twig' with { title: item.title, text: item.text } only %}
      {% endfor %}
    </div>
  </div>
</section>
