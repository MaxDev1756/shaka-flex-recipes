{% set title = title ?? 'Ready to start?' %}
{% set text = text ?? 'Install Shaka, preview the components and adapt them to your project.' %}
{% set primary = primary ?? { label: 'See showcase', href: '/shaka/showcase' } %}
{% set secondary = secondary ?? { label: 'Read content page', href: '/shaka/content', variant: 'secondary' } %}
<section class="shaka-cta">
  <div class="shaka-container shaka-cta__inner">
    <div><h2>{{ title }}</h2><p>{{ text }}</p></div>
    <div class="shaka-cta__actions">
      {% include 'shaka/components/_button.html.twig' with primary only %}
      {% include 'shaka/components/_button.html.twig' with secondary only %}
    </div>
  </div>
</section>
