{% set title = title ?? 'Testimonials' %}
{% set items = items ?? [
  { name: 'Marie Dupont', role: 'Product designer', quote: 'Shaka gives me a clear starting point instead of an empty page.' },
  { name: 'Nicolas Martin', role: 'Symfony developer', quote: 'I can find the right template and CSS file immediately.' }
] %}
<section class="shaka-testimonials">
  <div class="shaka-container">
    <div class="shaka-section-heading"><h2>{{ title }}</h2></div>
    <div class="shaka-testimonials__grid">
      {% for item in items %}
        <article class="shaka-testimonial">
          <p class="shaka-testimonial__quote">“{{ item.quote }}”</p>
          <div class="shaka-testimonial__author">
            {% include 'shaka/components/_avatar.html.twig' with { name: item.name, size: 'sm' } only %}
            <div><strong>{{ item.name }}</strong><span>{{ item.role }}</span></div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
