{#
  sections/_testimonials.html.twig
  =================================
  Customer testimonials / quotes section.

  Variables:
    - heading     (string) : Section heading.
    - subheading  (string) : Section subtext.
    - eyebrow     (string) : Small label above heading.
    - testimonials (array) : [
        {
          quote   (string) : The testimonial text. Required.
          author  (object) : {
            name    (string),
            role    (string),
            company (string),
            avatar  (object): { src, alt }
          },
          rating (number) : Star rating 1–5,
          badge  (string) : Optional highlight badge text
        }
      ]
    - layout   (string) : 'grid' | 'carousel' | 'masonry'. Default: 'grid'
    - columns  (number) : 1 | 2 | 3. Default: 3
    - featured (number) : Index of a featured/larger testimonial.

  Usage:
    {% include 'sections/_testimonials.html.twig' with {
      heading: 'Ils nous font confiance',
      testimonials: [
        {
          quote: 'Un outil indispensable pour toute notre équipe.',
          author: { name: 'Marie Leblanc', role: 'CTO', company: 'Acme Corp' },
          rating: 5
        }
      ]
    } %}
#}

<section data-section="testimonials" data-layout="{{ layout|default('grid') }}">

  {% if heading is defined or subheading is defined %}
    <header data-section-header>
      {% if eyebrow is defined and eyebrow %}
        <p data-section-eyebrow>{{ eyebrow }}</p>
      {% endif %}
      {% if heading is defined and heading %}
        <h2 data-section-heading>{{ heading }}</h2>
      {% endif %}
      {% if subheading is defined and subheading %}
        <p data-section-subheading>{{ subheading }}</p>
      {% endif %}
    </header>
  {% endif %}

  {% if testimonials is defined and testimonials|length %}
    <ul
      role="list"
      data-testimonials-grid
      data-columns="{{ columns|default(3) }}">

      {% for testimonial in testimonials %}
        <li
          data-testimonial-item
          {% if featured is defined and loop.index0 == featured %}data-featured{% endif %}>

          {# Star rating #}
          {% if testimonial.rating is defined %}
            <div data-testimonial-rating aria-label="Note : {{ testimonial.rating }} sur 5">
              {% for i in 1..5 %}
                <span aria-hidden="true">{{ i <= testimonial.rating ? '★' : '☆' }}</span>
              {% endfor %}
            </div>
          {% endif %}

          {# Badge #}
          {% if testimonial.badge is defined %}
            {% include 'components/_badge.html.twig' with { label: testimonial.badge, variant: 'primary' } %}
          {% endif %}

          {# Quote #}
          <blockquote data-testimonial-quote>
            <p>{{ testimonial.quote }}</p>
          </blockquote>

          {# Author #}
          {% if testimonial.author is defined %}
            <footer data-testimonial-author>
              {% if testimonial.author.avatar is defined %}
                {% include 'components/_avatar.html.twig' with {
                  src:  testimonial.author.avatar.src,
                  alt:  testimonial.author.avatar.alt|default(testimonial.author.name),
                  name: testimonial.author.name,
                  size: 'md'
                } %}
              {% endif %}
              <div>
                <cite data-author-name>{{ testimonial.author.name }}</cite>
                {% if testimonial.author.role is defined or testimonial.author.company is defined %}
                  <p data-author-meta>
                    {{ testimonial.author.role|default('') }}
                    {% if testimonial.author.role is defined and testimonial.author.company is defined %}, {% endif %}
                    {{ testimonial.author.company|default('') }}
                  </p>
                {% endif %}
              </div>
            </footer>
          {% endif %}

        </li>
      {% endfor %}

    </ul>
  {% endif %}

</section>
