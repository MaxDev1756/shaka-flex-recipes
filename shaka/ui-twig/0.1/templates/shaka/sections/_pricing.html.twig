{% set plans = plans ?? [
  { name: 'Starter', price: '0€', text: 'For trying the library.', cta: { label: 'Start free', href: '#' } },
  { name: 'Pro', price: '29€', text: 'For building production pages faster.', cta: { label: 'Choose Pro', href: '#', variant: 'secondary' } }
] %}
<section class="shaka-pricing">
  <div class="shaka-container">
    <div class="shaka-section-heading">
      <h2>{{ title ?? 'Simple pricing' }}</h2>
      <p>{{ text ?? 'Use these cards as a clean starting point.' }}</p>
    </div>
    <div class="shaka-pricing__grid">
      {% for plan in plans %}
        <article class="shaka-pricing-card">
          <h3>{{ plan.name }}</h3>
          <p class="shaka-pricing-card__price">{{ plan.price }}</p>
          <p>{{ plan.text }}</p>
          {% include 'shaka/components/_button.html.twig' with plan.cta only %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>
