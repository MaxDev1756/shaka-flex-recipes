{% set items = items ?? [
  { question: 'Can I change the design?', answer: 'Yes. Each component has a dedicated CSS file and simple Twig defaults.' },
  { question: 'Do I need JavaScript?', answer: 'Only for advanced interactions. The base UI works without JS.' }
] %}
<section class="shaka-faq">
  <div class="shaka-container">
    <div class="shaka-section-heading"><h2>{{ title ?? 'Frequently asked questions' }}</h2></div>
    <div class="shaka-faq__list">
      {% for item in items %}
        <article class="shaka-faq__item">
          <h3>{{ item.question }}</h3>
          <p>{{ item.answer }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
