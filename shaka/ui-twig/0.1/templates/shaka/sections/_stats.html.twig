{% set items = items ?? [
  { value: '12', label: 'UI components' },
  { value: '4', label: 'Starter pages' },
  { value: '1', label: 'Showcase route' }
] %}
<section class="shaka-stats">
  <div class="shaka-container shaka-stats__grid">
    {% for item in items %}
      <article class="shaka-stat">
        <strong class="shaka-stat__value">{{ item.value }}</strong>
        <span class="shaka-stat__label">{{ item.label }}</span>
      </article>
    {% endfor %}
  </div>
</section>
