{# ───────────────────────────────────────────────────────────
   Partial: Topbar
   ───────────────────────────────────────────────────────────
   Variables:
     nav_links   array  [{ label, href }]  Override default links
     api_name    string Brand name
     api_acronym string 2-char mark
     api_version string Version badge
#}
{% set current_path = app.request.pathInfo ?? '' %}

{% set nav_links = nav_links ?? [
  { label: 'Overview',   href: '/shaka/api' },
  { label: 'Reference',  href: '/shaka/api/reference' },
  { label: 'Errors',     href: '/shaka/api/errors' }
] %}

<header class="shaka-api-topbar" role="banner">
  <div class="shaka-api-topbar__inner">

    {# ── Brand ── #}
    <a class="shaka-api-topbar__brand"
       href="/shaka/api"
       aria-label="{{ api_name ?? 'API Docs' }}">
      <span class="shaka-api-topbar__brand-mark" aria-hidden="true">
        {{- api_acronym ?? 'AP' -}}
      </span>
      <span>{{ api_name ?? 'Shaka API' }}</span>
    </a>

    {# ── Desktop navigation ── #}
    <nav class="shaka-api-topbar__nav" aria-label="Primary navigation">
      {% for link in nav_links %}
        {# Exact match only — prevents /shaka/api matching /shaka/api/reference #}
        <a class="shaka-api-topbar__link{% if current_path == link.href %} is-active{% endif %}"
           href="{{ link.href }}"
           {% if current_path == link.href %}aria-current="page"{% endif %}>
          {{- link.label -}}
        </a>
      {% endfor %}
    </nav>

    {# ── Right actions ── #}
    <div class="shaka-api-topbar__actions">
      {% if api_version is defined and api_version %}
        <span class="shaka-api-topbar__badge">v{{ api_version }}</span>
      {% endif %}

      {# Burger — opens sidebar via direct DOM reference (cross-scope) #}
      <button class="shaka-api-topbar__burger"
              type="button"
              aria-label="Open navigation"
              aria-expanded="false"
              onclick="document.querySelector('.shaka-api-sidebar')?.__shakaSidebar?.open(); this.setAttribute('aria-expanded', 'true')">
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <line x1="2" y1="4"  x2="14" y2="4"/>
          <line x1="2" y1="8"  x2="14" y2="8"/>
          <line x1="2" y1="12" x2="14" y2="12"/>
        </svg>
      </button>
    </div>

  </div>
</header>
