{# ───────────────────────────────────────────────────────────
   Partial: Sidebar navigation
   ───────────────────────────────────────────────────────────
   Variables:
     sidebar_groups  array  Override default navigation groups
       [{
         title: 'Section name',
         items: [{ label, href, method? }]
       }]
     api_name    string
     api_acronym string
     api_version string
#}
{% set current_path = app.request.pathInfo ?? '' %}

{% set sidebar_groups = sidebar_groups ?? [
  {
    title: 'Getting started',
    items: [
      { label: 'Overview',       href: '/shaka/api' },
      { label: 'Authentication', href: '#authentication' },
      { label: 'Rate limiting',  href: '#rate-limiting' },
      { label: 'Pagination',     href: '#pagination' }
    ]
  },
  {
    title: 'Resources',
    items: [
      { label: 'Reference',      href: '/shaka/api/reference' },
      { label: 'Error handling', href: '/shaka/api/errors' }
    ]
  }
] %}

<aside class="shaka-api-sidebar"
       data-controller="shaka-sidebar"
       aria-label="Documentation navigation">

  {# ── Header: brand + close button ── #}
  <div class="shaka-api-sidebar__header">
    <a class="shaka-api-sidebar__brand" href="/shaka/api">
      <span class="shaka-api-sidebar__mark" aria-hidden="true">
        {{- api_acronym ?? 'AP' -}}
      </span>
      <div class="shaka-api-sidebar__brand-info">
        <span class="shaka-api-sidebar__brand-name">{{ api_name ?? 'Shaka API' }}</span>
        {% if api_version is defined and api_version %}
          <span class="shaka-api-sidebar__brand-version">v{{ api_version }}</span>
        {% endif %}
      </div>
    </a>

    <button class="shaka-api-sidebar__close"
            type="button"
            aria-label="Close navigation"
            data-action="click->shaka-sidebar#close">✕</button>
  </div>

  {# ── Navigation ── #}
  <nav aria-label="Sidebar navigation">
    {% for group in sidebar_groups %}
      <div class="shaka-api-sidebar__section">
        {% if group.title is defined and group.title %}
          <p class="shaka-api-sidebar__group-label" aria-hidden="true">
            {{ group.title }}
          </p>
        {% endif %}

        <ul class="shaka-api-sidebar__list" role="list">
          {% for item in group.items %}
            {% set is_page_link = not (item.href starts with '#') %}
            {% set is_active = is_page_link and current_path == item.href %}

            <li>
              <a class="shaka-api-sidebar__link{% if is_active %} is-active{% endif %}"
                 href="{{ item.href }}"
                 {% if is_active %}aria-current="page"{% endif %}>

                {% if item.method is defined and item.method %}
                  <span class="shaka-api-sidebar__method shaka-api-sidebar__method--{{ item.method|lower }}"
                        aria-label="{{ item.method }}">
                    {{- item.method -}}
                  </span>
                {% else %}
                  <span class="shaka-api-sidebar__dot" aria-hidden="true"></span>
                {% endif %}

                <span>{{ item.label }}</span>
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endfor %}
  </nav>

</aside>
