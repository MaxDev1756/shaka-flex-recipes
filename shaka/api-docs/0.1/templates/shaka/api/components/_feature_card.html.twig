{# ───────────────────────────────────────────────────────────
   Component: Feature Card
   Variables: title, text, icon (emoji/HTML), href (optional)
#}
{% set title = title ?? 'Feature' %}
{% set text  = text  ?? '' %}

{% if href is defined %}
  <a class="shaka-feature-card" href="{{ href }}">
{% else %}
  <div class="shaka-feature-card">
{% endif %}

  {% if icon is defined and icon %}
    <div class="shaka-feature-card__icon" aria-hidden="true">{{ icon }}</div>
  {% endif %}

  <h3 class="shaka-feature-card__title">{{ title }}</h3>

  {% if text %}
    <p class="shaka-feature-card__text">{{ text }}</p>
  {% endif %}

{% if href is defined %}
  </a>
{% else %}
  </div>
{% endif %}
