{# ───────────────────────────────────────────────────────────
   Component: Code Block with language tabs
   ───────────────────────────────────────────────────────────
   Variables:
     title     string  Optional header label
     snippets  object  { 'bash': 'code...', 'php': 'code...' }
#}
{% set title    = title    ?? '' %}
{% set snippets = snippets ?? {
  'bash':       'curl https://api.example.com/v1/users',
  'php':        '$client->request("GET", "/v1/users");',
  'javascript': 'await fetch("/v1/users");'
} %}

<section class="shaka-code-block" data-controller="shaka-code-tabs">

  <header class="shaka-code-block__bar">

    {# Language tabs #}
    <div class="shaka-code-block__tabs" role="tablist" aria-label="{{ title ?: 'Code example' }}">
      {% for language, snippet in snippets %}
        <button
          type="button"
          class="shaka-code-block__tab{% if loop.first %} is-active{% endif %}"
          role="tab"
          aria-selected="{{ loop.first ? 'true' : 'false' }}"
          aria-controls="panel-{{ language }}-{{ loop.index }}"
          tabindex="{{ loop.first ? '0' : '-1' }}"
          data-action="click->shaka-code-tabs#select keydown->shaka-code-tabs#keydown"
          data-shaka-code-tabs-target="tab"
          data-shaka-code-tabs-language-param="{{ language }}"
        >
          {{- language|upper -}}
        </button>
      {% endfor %}
    </div>

    {# Copy button — same controller scope, finds sibling panel automatically #}
    <button
      type="button"
      class="shaka-code-block__copy"
      data-controller="shaka-copy-code"
      data-action="click->shaka-copy-code#copy"
      aria-label="Copy code to clipboard"
    >
      <svg class="shaka-code-block__copy-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="5" y="5" width="9" height="9" rx="1.5"/>
        <path d="M3 11V3a2 2 0 0 1 2-2h8" stroke-linecap="round"/>
      </svg>
      Copy
    </button>

  </header>

  {# Code panels #}
  {% for language, snippet in snippets %}
    <div
      class="shaka-code-block__panel{% if loop.first %} is-active{% endif %}"
      role="tabpanel"
      id="panel-{{ language }}-{{ loop.index }}"
      data-shaka-code-tabs-target="panel"
      data-language="{{ language }}"
      {% if not loop.first %}hidden{% endif %}
    >
      <pre><code class="language-{{ language }}">{{ snippet }}</code></pre>
    </div>
  {% endfor %}

</section>
