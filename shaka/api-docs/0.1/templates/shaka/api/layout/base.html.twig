{% set page_title = page_title ?? 'API Documentation' %}
<!DOCTYPE html>
<html lang="{{ app.request.locale ?? 'en' }}">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ page_description ?? 'API Reference Documentation' }}">
    <title>{% block title %}{{ page_title }}{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {{ importmap('app') }}
  </head>
  <body class="shaka-api-body">

    {% block topbar %}
      {% include 'shaka/api/partials/_topbar.html.twig' %}
    {% endblock %}

    {% block shell %}{% endblock %}

    {# Mobile sidebar overlay backdrop #}
    <div class="shaka-sidebar-backdrop"
         aria-hidden="true"
         data-action="click->shaka-sidebar#close"
         style="display:none"></div>

  </body>
</html>
