{% extends 'shaka/api/layout/base.html.twig' %}

{% block title %}{{ api_name ?? 'API' }} — Error codes{% endblock %}

{% block shell %}
<main class="shaka-api-page shaka-api-page--errors">
  <div class="shaka-api-page__grid">

    {% include 'shaka/api/partials/_sidebar.html.twig' with {
      sidebar_groups: [
        {
          title: 'Pages',
          items: [
            { label: 'Overview',        href: '/shaka/api' },
            { label: 'Reference',       href: '/shaka/api/reference' },
            { label: 'Errors',          href: '/shaka/api/errors' }
          ]
        },
        {
          title: 'On this page',
          items: [
            { label: 'Error object',    href: '#error-structure' },
            { label: 'Error codes',     href: '#error-codes' },
            { label: 'HTTP statuses',   href: '#status-codes' },
            { label: 'Handling errors', href: '#handling-errors' }
          ]
        }
      ]
    } %}

    <div class="shaka-api-page__content">

      {# ── Page header ── #}
      <div class="shaka-page-header">
        <div class="shaka-page-header__eyebrow">
          <span class="shaka-badge shaka-badge--danger">Errors</span>
        </div>
        <h1 class="shaka-page-header__title">Error handling</h1>
        <p class="shaka-page-header__subtitle">
          All errors return a consistent JSON envelope. Use the <code>error.code</code> field to handle specific cases programmatically.
        </p>
      </div>

      {# ── Error object ── #}
      <section id="error-structure" class="shaka-section">
        <h2>Error object</h2>
        <p>Every error response wraps the failure in an <code>error</code> object at the top level:</p>

        {% include 'shaka/api/components/_response_table.html.twig' with {
          caption: 'Error response fields',
          rows: [
            { field: 'error.code',    type: 'string', required: true,  description: 'Machine-readable error code, e.g. validation_failed.' },
            { field: 'error.message', type: 'string', required: true,  description: 'Human-readable description of the error.' },
            { field: 'error.details', type: 'array',  required: false, description: 'Field-level validation errors (422 only).' },
            { field: 'request_id',    type: 'string', required: true,  description: 'Trace ID — always include this in support requests.' }
          ]
        } only %}
      </section>

      {# ── Error codes ── #}
      <section id="error-codes" class="shaka-section">
        <h2>Error codes</h2>
        <p>The <code>error.code</code> field is a stable, versioned string you can match in your code:</p>

        {% include 'shaka/api/components/_response_table.html.twig' with {
          rows: [
            { field: 'bad_request',        type: '400', description: 'Malformed JSON body or missing Content-Type header.' },
            { field: 'unauthorized',       type: '401', description: 'Missing or expired bearer token.' },
            { field: 'forbidden',          type: '403', description: 'Token is valid but lacks the required permission.' },
            { field: 'not_found',          type: '404', description: 'The requested resource does not exist or was deleted.' },
            { field: 'validation_failed',  type: '422', description: 'One or more request body fields failed validation.' },
            { field: 'rate_limited',       type: '429', description: 'Too many requests — see Retry-After header.' },
            { field: 'internal_error',     type: '500', description: 'Unexpected server error. Use request_id when reporting.' },
            { field: 'service_unavailable',type: '503', description: 'The service is temporarily offline. Retry after a delay.' }
          ]
        } only %}
      </section>

      {# ── Example error response ── #}
      <section id="error-example" class="shaka-section">
        <h2>Example error response</h2>

        {% include 'shaka/api/components/_endpoint_card.html.twig' with {
          method:      'POST',
          path:        '/v1/users',
          title:       'Validation error (422)',
          description: 'Returned when required fields are missing or fail schema validation.',
          responses: [
            { code: 422, label: 'Validation failed' },
            { code: 401, label: 'Unauthorized' }
          ]
        } only %}

        {% include 'shaka/api/components/_code_tabs.html.twig' with {
          snippets: {
            'json': '{
  "error": {
    "code": "validation_failed",
    "message": "The request body is invalid.",
    "details": [
      { "field": "email",    "message": "The email field is required." },
      { "field": "password", "message": "Must be at least 8 characters." }
    ]
  },
  "request_id": "req_9fa23b4c"
}',
            'php': '// Catch validation errors
$data = $response->toArray(false);
if ($data["error"]["code"] === "validation_failed") {
    foreach ($data["error"]["details"] as $detail) {
        echo $detail["field"] . ": " . $detail["message"] . "\n";
    }
}',
            'javascript': 'const res = await fetch("/v1/users", { method: "POST", body });
const { error } = await res.json();

if (!res.ok) {
  if (error.code === "validation_failed") {
    error.details.forEach(d => console.error(d.field, d.message));
  }
}'
          }
        } only %}
      </section>

      {# ── HTTP status codes ── #}
      <section id="status-codes" class="shaka-section">
        <h2>HTTP status codes</h2>

        <div class="shaka-table-wrap">
          <table class="shaka-table">
            <thead>
              <tr>
                <th scope="col">Status</th>
                <th scope="col">Meaning</th>
                <th scope="col">When it occurs</th>
              </tr>
            </thead>
            <tbody>
              {% set statuses = [
                { code: 200, label: 'OK',                  desc: 'Request succeeded.' },
                { code: 201, label: 'Created',             desc: 'Resource created successfully.' },
                { code: 204, label: 'No Content',          desc: 'Success with no response body (e.g. DELETE).' },
                { code: 400, label: 'Bad Request',         desc: 'Malformed JSON or missing Content-Type.' },
                { code: 401, label: 'Unauthorized',        desc: 'Missing or invalid bearer token.' },
                { code: 403, label: 'Forbidden',           desc: 'Valid token but insufficient permissions.' },
                { code: 404, label: 'Not Found',           desc: 'Resource does not exist or was deleted.' },
                { code: 422, label: 'Unprocessable',       desc: 'Request body failed schema validation.' },
                { code: 429, label: 'Too Many Requests',   desc: 'Rate limit exceeded — check Retry-After.' },
                { code: 500, label: 'Internal Error',      desc: 'Unexpected server error — include request_id.' },
                { code: 503, label: 'Service Unavailable', desc: 'Scheduled maintenance or overload.' }
              ] %}

              {% for s in statuses %}
                <tr>
                  <td>
                    <span class="shaka-endpoint__status" data-code="{{ s.code }}">
                      {{ s.code }} {{ s.label }}
                    </span>
                  </td>
                  <td><code>{{ s.code }}</code></td>
                  <td>{{ s.desc }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </section>

      {# ── Handling errors ── #}
      <section id="handling-errors" class="shaka-section">
        <h2>Handling errors in code</h2>

        {% include 'shaka/api/components/_alert.html.twig' with {
          type:  'success',
          title: 'Retry on 429 with backoff',
          text:  'Use exponential backoff when you receive a 429. Always check the Retry-After header for the exact wait time.'
        } only %}

        {% include 'shaka/api/components/_alert.html.twig' with {
          type:  'danger',
          title: 'Never retry 4xx errors (except 429)',
          text:  'Errors 400, 401, 403, 404 and 422 indicate a problem with your request. Fix it before retrying.'
        } only %}

        {% include 'shaka/api/components/_alert.html.twig' with {
          type:  'warning',
          title: 'Include request_id in support tickets',
          text:  'The request_id is logged on every request. It allows our team to trace the exact cause of a 5xx error.'
        } only %}
      </section>

    </div>{# .shaka-api-page__content #}
  </div>{# .shaka-api-page__grid #}
</main>
{% endblock %}
