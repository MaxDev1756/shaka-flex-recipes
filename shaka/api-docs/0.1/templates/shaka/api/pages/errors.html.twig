{% extends 'shaka/api/layout/base.html.twig' %}

{% block title %}{{ api_name ?? 'API' }} — Error codes{% endblock %}

{% block shell %}
<main class="shaka-api-page shaka-api-page--errors">
  <div class="shaka-api-page__grid">

    {% include 'shaka/api/partials/_sidebar.html.twig' %}

    <div class="shaka-api-page__content">

      <header class="shaka-reference-header">
        <span class="shaka-api-badge">Errors</span>
        <h1>Error handling</h1>
        <p>All errors return a JSON object with a consistent structure. Use the <code>error.code</code> field to handle specific cases in your application.</p>
      </header>

      {# ── Error structure ── #}
      <section id="error-structure" class="shaka-section">
        <h2>Error object</h2>

        {% include 'shaka/api/components/_response_table.html.twig' with {
          caption: 'Error response fields',
          rows: [
            { field: 'error.code',    type: 'string', required: true,  description: 'Machine-readable error code, e.g. validation_failed.' },
            { field: 'error.message', type: 'string', required: true,  description: 'Human-readable error description.' },
            { field: 'error.details', type: 'array',  required: false, description: 'Array of field-level validation messages.' },
            { field: 'request_id',    type: 'string', required: true,  description: 'Trace ID — include in support requests.' }
          ]
        } only %}
      </section>

      {# ── Example error ── #}
      <section id="error-example" class="shaka-section">
        <h2>Example error response</h2>

        {% include 'shaka/api/components/_endpoint_card.html.twig' with {
          method:      'POST',
          path:        '/v1/users',
          title:       'Validation error example',
          description: 'Returned when required fields are missing or invalid.',
          responses: [
            { code: 422, label: 'Validation failed' },
            { code: 401, label: 'Unauthorized' }
          ]
        } only %}

        {% include 'shaka/api/components/_code_tabs.html.twig' with {
          title:    'Error response payload',
          snippets: {
            'json': '{\n  "error": {\n    "code": "validation_failed",\n    "message": "The request body is invalid.",\n    "details": [\n      { "field": "email", "message": "The email field is required." }\n    ]\n  },\n  "request_id": "req_9fa23b4c"\n}',
            'php':        '$code = $response["error"]["code"]; // "validation_failed"\n$msg  = $response["error"]["message"];',
            'javascript': 'const { error } = await res.json();\nconsole.error(error.code); // "validation_failed"'
          }
        } only %}
      </section>

      {# ── HTTP status codes table ── #}
      <section id="status-codes" class="shaka-section">
        <h2>HTTP status codes</h2>

        <div class="shaka-table-wrap">
          <table class="shaka-table">
            <thead>
              <tr>
                <th>Status</th>
                <th>Code</th>
                <th>When it occurs</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><span class="shaka-endpoint__response" data-code="200">200</span></td>
                <td><code>ok</code></td>
                <td>Request succeeded.</td>
              </tr>
              <tr>
                <td><span class="shaka-endpoint__response" data-code="201">201</span></td>
                <td><code>created</code></td>
                <td>Resource was created successfully.</td>
              </tr>
              <tr>
                <td><span class="shaka-endpoint__response" data-code="400">400</span></td>
                <td><code>bad_request</code></td>
                <td>Malformed JSON or missing Content-Type header.</td>
              </tr>
              <tr>
                <td><span class="shaka-endpoint__response" data-code="401">401</span></td>
                <td><code>unauthorized</code></td>
                <td>Missing or invalid bearer token.</td>
              </tr>
              <tr>
                <td><span class="shaka-endpoint__response" data-code="403">403</span></td>
                <td><code>forbidden</code></td>
                <td>Valid token but insufficient permissions.</td>
              </tr>
              <tr>
                <td><span class="shaka-endpoint__response" data-code="404">404</span></td>
                <td><code>not_found</code></td>
                <td>Resource does not exist or was deleted.</td>
              </tr>
              <tr>
                <td><span class="shaka-endpoint__response" data-code="422">422</span></td>
                <td><code>validation_failed</code></td>
                <td>Request body failed schema validation.</td>
              </tr>
              <tr>
                <td><span class="shaka-endpoint__response" data-code="429">429</span></td>
                <td><code>rate_limited</code></td>
                <td>Too many requests — see Retry-After header.</td>
              </tr>
              <tr>
                <td><span class="shaka-endpoint__response" data-code="500">500</span></td>
                <td><code>internal_error</code></td>
                <td>Unexpected server error. Include request_id in support requests.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      {# ── Alert examples ── #}
      <section id="alerts" class="shaka-section">
        <h2>Handling errors in code</h2>

        {% include 'shaka/api/components/_alert.html.twig' with {
          type:  'success',
          title: 'Retry on 429',
          text:  'Use exponential backoff when you receive a 429. Check the Retry-After response header for the wait duration.'
        } only %}

        {% include 'shaka/api/components/_alert.html.twig' with {
          type:  'danger',
          title: 'Never retry on 4xx (except 429)',
          text:  'Client errors (400, 401, 403, 404, 422) indicate a problem with the request itself. Fix the request before retrying.'
        } only %}
      </section>

    </div>{# .shaka-api-page__content #}
  </div>{# .shaka-api-page__grid #}
</main>
{% endblock %}
